{
  "name": "agent-workspace-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop UI for Antigravity CLI, Codex CLI and Claude Code",
  "author": "Agent Workspace",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --port=3000 --host=127.0.0.1\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:3000 electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^8.0.16",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "app.agentworkspace.desktop",
    "productName": "Agent Workspace",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
